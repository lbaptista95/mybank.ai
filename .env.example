# ============================================================
# MyBankAI - Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# JWT
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_ISSUER=MyBankAI
JWT_AUDIENCE=MyBankAI.Clients
JWT_EXPIRY_MINUTES=60

# PostgreSQL
POSTGRES_USER=fintech
POSTGRES_PASSWORD=fintech_secret_2024
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

ACCOUNT_DB_NAME=accountdb
TRANSACTION_DB_NAME=transactiondb
FRAUD_DB_NAME=frauddb
NOTIFICATION_DB_NAME=notificationdb

ACCOUNT_DB_CONNECTION=Host=postgres;Port=5432;Database=accountdb;Username=fintech;Password=fintech_secret_2024
TRANSACTION_DB_CONNECTION=Host=postgres;Port=5432;Database=transactiondb;Username=fintech;Password=fintech_secret_2024
FRAUD_DB_CONNECTION=Host=postgres;Port=5432;Database=frauddb;Username=fintech;Password=fintech_secret_2024
NOTIFICATION_DB_CONNECTION=Host=postgres;Port=5432;Database=notificationdb;Username=fintech;Password=fintech_secret_2024

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID_FRAUD=fraud-detection-group
KAFKA_GROUP_ID_NOTIFICATION=notification-group

# Groq API (https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Service URLs (internal docker network)
ACCOUNT_SERVICE_URL=http://account-service:8080
TRANSACTION_SERVICE_URL=http://transaction-service:8080
FRAUD_SERVICE_URL=http://fraud-service:8080
NOTIFICATION_SERVICE_URL=http://notification-service:8080

# Serilog / Seq (optional log sink)
SEQ_URL=http://seq:5341
