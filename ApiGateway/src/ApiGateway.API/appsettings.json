{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Yarp": "Warning"
      }
    }
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "MyBankAI",
    "Audience": "MyBankAI.Clients"
  },
  "ReverseProxy": {
    "Routes": {
      "account-route": {
        "ClusterId": "account-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/accounts/{**catch-all}"
        }
      },
      "account-auth-route": {
        "ClusterId": "account-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/accounts/users/{action=register|login}"
        }
      },
      "transaction-route": {
        "ClusterId": "transaction-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/transactions/{**catch-all}"
        }
      },
      "fraud-route": {
        "ClusterId": "fraud-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/fraud/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "account-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "account-service": {
            "Address": "http://account-service:8080"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "transaction-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "transaction-service": {
            "Address": "http://transaction-service:8080"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "fraud-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "fraud-service": {
            "Address": "http://fraud-service:8080"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
